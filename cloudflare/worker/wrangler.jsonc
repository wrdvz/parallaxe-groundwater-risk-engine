{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "parallaxe-groundwater-risk-engine-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-15",
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "parallaxe-groundwater-risk-engine",
      "database_id": "d0a34db9-240d-4590-93ca-42e172e406c9"
    }
  ],
  "vars": {
    "APP_NAME": "parallaxe-groundwater-risk-engine",
    "APP_STAGE": "mvp"
  },
